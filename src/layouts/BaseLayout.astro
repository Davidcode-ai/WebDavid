---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'Diseño de páginas web profesionales y económicas en España. Especialista en webs para psicólogos, electricistas y PYMES.',
  canonical = 'https://webdavid.es/',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="David - WebDavid.es" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />

    <slot name="head" />
  </head>
  <body class="antialiased selection:bg-brand-500 selection:text-white">
    <slot />
    <slot name="scripts" />
    <script src="../scripts/reveal.js"></script>
  </body>
</html>
