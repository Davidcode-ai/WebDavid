---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import electricistaImg from '../assets/images/electricista.png';
import etnaImg from '../assets/images/etnapsicologia.png';
---

<BaseLayout
  title="WebDavid | Diseño Web Freelance (Desde 180€)"
  description="Diseño de páginas web profesionales y económicas en España. Especialista en webs para psicólogos, electricistas y PYMES. ¡Pide presupuesto en 1 min!"
  canonical="https://webdavid.es/"
>
  <Fragment slot="head">
    <meta property="og:title" content="WebDavid | Tu Web Profesional por 180€" />
    <meta property="og:description" content="Mira mis proyectos reales. Diseño webs rápidas que posicionan en Google." />
    <meta property="og:url" content="https://webdavid.es/" />
    <meta property="og:type" content="website" />
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "WebDavid",
        "url": "https://webdavid.es",
        "priceRange": "180€-800€",
        "description": "Diseño web a medida y WordPress para negocios locales."
      }
    </script>
  </Fragment>

    <nav class="fixed w-full z-50 transition-all duration-300 glass-card">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <a href="#" class="font-display font-bold text-2xl tracking-tight text-white flex items-center gap-2 z-50">
                    <span class="text-brand-400">&lt;/&gt;</span> WebDavid
                </a>
                <div class="hidden md:flex space-x-8 items-center">
                    <a href="#servicios" class="text-gray-400 hover:text-white transition font-medium text-sm uppercase tracking-wider">Servicios</a>
                    <a href="#portfolio" class="text-gray-400 hover:text-white transition font-medium text-sm uppercase tracking-wider">Trabajos</a>
                    <a href="#pricing" class="text-gray-400 hover:text-white transition font-medium text-sm uppercase tracking-wider">Precios</a>
                    <a href="https://wa.me/34600000000" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp" class="bg-white text-dark-900 px-6 py-2.5 rounded-full font-bold hover:bg-brand-400 transition hover:scale-105 shadow-lg shadow-brand-500/20 text-sm">Contactar</a>
                </div>
                <button id="mobile-menu-btn" aria-label="Abrir menú de navegación" aria-expanded="false" class="md:hidden text-white text-2xl p-2 focus:outline-none z-50">
                    <i class="fa-solid fa-bars transition-transform duration-300"></i>
                </button>
            </div>
        </div>
        <div id="mobile-menu" class="absolute top-20 left-0 w-full bg-[#0B0F19] border-b border-gray-800 shadow-2xl md:hidden transform -translate-y-[150%] transition-transform duration-300 ease-in-out -z-10">
            <div class="flex flex-col items-center py-8 space-y-8">
                <a href="#servicios" onclick="toggleMenu()" class="text-xl text-white font-bold hover:text-brand-400 tracking-wide">SERVICIOS</a>
                <a href="#portfolio" onclick="toggleMenu()" class="text-xl text-white font-bold hover:text-brand-400 tracking-wide">TRABAJOS</a>
                <a href="#pricing" onclick="toggleMenu()" class="text-xl text-white font-bold hover:text-brand-400 tracking-wide">PRECIOS</a>
                <div class="w-16 h-px bg-gray-800"></div>
                <a href="https://wa.me/34600000000" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp" class="bg-brand-600 text-white px-8 py-3 rounded-xl font-bold text-lg shadow-lg flex items-center gap-2"><i class="fa-brands fa-whatsapp" aria-hidden="true"></i> WhatsApp</a>
            </div>
        </div>
    </nav>

    <main>
    <section class="relative pt-32 pb-16 lg:pt-48 lg:pb-32 overflow-hidden px-4">
        <div class="absolute top-0 right-0 w-64 md:w-96 h-64 md:h-96 bg-brand-500 rounded-full mix-blend-multiply filter blur-[128px] opacity-20 animate-blob"></div>
        <div class="absolute bottom-0 left-0 w-64 md:w-96 h-64 md:h-96 bg-purple-500 rounded-full mix-blend-multiply filter blur-[128px] opacity-20 animate-blob animation-delay-2000"></div>
        <div class="max-w-7xl mx-auto text-center" data-aos="fade-up">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 md:px-4 md:py-2 rounded-full bg-gray-800 border border-gray-700 text-xs md:text-sm text-gray-300 mb-6 md:mb-8">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                Especialista en Webs para Negocios Locales
            </div>
            <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-6 leading-[1.1]">
                Diseño Web que <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-purple-500">vende por ti.</span>
            </h1>
            <p class="mt-4 md:mt-6 max-w-2xl mx-auto text-base md:text-xl text-gray-400 mb-8 md:mb-10 leading-relaxed px-2">
                Digitalizo tu negocio. Desde una web rápida para que te llamen, hasta una presencia completa en Google.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4 px-2">
                <button onclick="toggleChat()" class="w-full sm:w-auto px-8 py-4 bg-blue-800 text-white rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-brand-500/25 ring-2 ring-blue-700 ring-offset-2 ring-offset-dark-900 active:scale-95">Calcula Presupuesto</button>
                <a href="#portfolio" class="w-full sm:w-auto px-8 py-4 bg-gray-800 text-white border border-gray-700 rounded-xl font-semibold hover:bg-gray-700 transition flex items-center justify-center gap-2 active:scale-95"><i class="fa-solid fa-eye"></i> Ver Ejemplos</a>
            </div>
        </div>
    </section>

    <section class="bg-dark-800 border-y border-gray-800 py-6 md:py-10 overflow-hidden relative">
        <div class="max-w-7xl mx-auto px-4 marquee-mask">
            <div class="flex w-[calc(250px*14)] animate-scroll">
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-html5 text-5xl text-orange-500"></i> <span class="font-bold text-xl text-gray-300">HTML5</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-wordpress text-5xl text-white"></i> <span class="font-bold text-xl text-gray-300">WordPress</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-css3-alt text-5xl text-blue-500"></i> <span class="font-bold text-xl text-gray-300">CSS3</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-elementor text-5xl text-[#E9286D]"></i> <span class="font-bold text-xl text-gray-300">Elementor</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-google text-5xl text-white"></i> <span class="font-bold text-xl text-gray-300">SEO</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-html5 text-5xl text-orange-500"></i> <span class="font-bold text-xl text-gray-300">HTML5</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-wordpress text-5xl text-white"></i> <span class="font-bold text-xl text-gray-300">WordPress</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-css3-alt text-5xl text-blue-500"></i> <span class="font-bold text-xl text-gray-300">CSS3</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-elementor text-5xl text-[#E9286D]"></i> <span class="font-bold text-xl text-gray-300">Elementor</span></div>
                <div class="w-[250px] flex justify-center items-center gap-3 hover:scale-110 transition"><i class="fa-brands fa-google text-5xl text-white"></i> <span class="font-bold text-xl text-gray-300">SEO</span></div>
            </div>
        </div>
    </section>

    <section id="servicios" class="py-16 md:py-24 relative px-4">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-10 md:mb-16">
                <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">¿Código o CMS?</h2>
                <p class="text-gray-400">Me adapto a lo que necesite tu negocio.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:auto-rows-[300px]">
                <div class="md:col-span-2 bg-gray-800 rounded-3xl p-6 md:p-8 border border-gray-700 relative overflow-hidden group hover:border-brand-500 transition duration-500" data-aos="fade-up">
                    <div class="absolute top-0 right-0 p-4 md:p-8 opacity-10 group-hover:opacity-20 transition text-7xl md:text-9xl text-white"><i class="fa-solid fa-code"></i></div>
                    <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Opción A: Código Puro</h3>
                    <p class="text-gray-400 max-w-md text-sm md:text-base leading-relaxed">Si quieres una web ultra rápida, segura y sin mantenimiento. Programada en HTML/CSS.</p>
                    <div class="mt-6 md:mt-8 flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-green-500/10 text-green-400 text-xs rounded border border-green-500/20">Carga &lt; 0.5s</span>
                        <span class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs rounded border border-blue-500/20">0 Mantenimiento</span>
                    </div>
                </div>
                <div class="md:row-span-2 bg-gradient-to-b from-gray-800 to-gray-900 rounded-3xl p-6 md:p-8 border border-gray-700 flex flex-col justify-between hover:border-pink-500 transition duration-500" data-aos="fade-up" data-aos-delay="100">
                    <div>
                        <div class="w-12 h-12 bg-pink-600 rounded-xl flex items-center justify-center text-white mb-6 text-xl"><i class="fa-brands fa-wordpress"></i></div>
                        <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Opción B: WordPress</h3>
                        <p class="text-gray-400 text-sm md:text-base leading-relaxed">¿Necesitas blog o cambiar textos tú mismo? Te instalo Panel de Control y Elementor.</p>
                    </div>
                    <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=400" width="400" height="267" class="rounded-xl opacity-50 mt-4 grayscale group-hover:grayscale-0 transition w-full object-cover h-32 md:h-auto" alt="Panel de administración de WordPress con Elementor" loading="lazy">
                </div>
                <div class="bg-gray-800 rounded-3xl p-6 md:p-8 border border-gray-700 hover:border-brand-500 transition duration-500" data-aos="fade-up">
                    <h3 class="text-lg md:text-xl font-bold text-white mb-2">Google Friendly</h3>
                    <p class="text-gray-400 text-sm">Estructura SEO optimizada.</p>
                    <div class="mt-4 text-brand-400 text-2xl"><i class="fa-brands fa-google"></i></div>
                </div>
                <div class="bg-gray-800 rounded-3xl p-6 md:p-8 border border-gray-700 hover:border-brand-500 transition duration-500" data-aos="fade-up" data-aos-delay="100">
                    <h3 class="text-lg md:text-xl font-bold text-white mb-2">100% Móvil</h3>
                    <p class="text-gray-400 text-sm">Se verá perfecta en iPhone.</p>
                    <div class="mt-4 text-brand-400 text-2xl"><i class="fa-solid fa-mobile-screen"></i></div>
                </div>
            </div>
        </div>
    </section>

    <section id="portfolio" class="py-16 md:py-24 bg-dark-800 px-4">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-12 text-center">Proyectos Reales</h2>
            <div class="grid md:grid-cols-2 gap-8">
                
                <a href="https://www.averiascadiz.es" target="_blank" class="group relative block" data-aos="fade-up">
                    <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-900 shadow-xl transition-transform duration-300 group-hover:-translate-y-2">
                        <Image
                            src={electricistaImg}
                            alt="Captura de pantalla de la web de Averías Cádiz, proyecto de electricista"
                            width={800}
                            height={450}
                            format="webp"
                            loading="lazy"
                            decoding="async"
                            class="w-full h-56 md:h-80 object-cover opacity-80 group-hover:opacity-100 transition duration-500"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-90"></div>
                        <div class="absolute bottom-0 left-0 p-6 w-full">
                            <div class="flex justify-between items-end">
                                <div>
                                    <h3 class="text-xl font-bold text-white group-hover:text-brand-400 transition">Averías Cádiz</h3>
                                    <p class="text-gray-300 mt-1 text-sm">Web Urgencias Electricidad</p>
                                </div>
                                <span class="text-brand-400 text-xs font-bold border border-brand-400 px-2 py-1 rounded hover:bg-brand-400 hover:text-white transition">Visitar ↗</span>
                            </div>
                            <div class="flex gap-2 mt-3">
                                <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded">HTML5</span>
                                <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded">SEO Local</span>
                            </div>
                        </div>
                    </div>
                </a>

                <a href="https://www.etnapsicologia.com" target="_blank" class="group relative block" data-aos="fade-up" data-aos-delay="100">
                    <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-900 shadow-xl transition-transform duration-300 group-hover:-translate-y-2">
                        <Image
                            src={etnaImg}
                            alt="Captura de pantalla de la web de Etna Psicología, proyecto WordPress con blog"
                            width={800}
                            height={450}
                            format="webp"
                            loading="lazy"
                            decoding="async"
                            class="w-full h-56 md:h-80 object-cover opacity-80 group-hover:opacity-100 transition duration-500"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-90"></div>
                        <div class="absolute bottom-0 left-0 p-6 w-full">
                            <div class="flex justify-between items-end">
                                <div>
                                    <h3 class="text-xl font-bold text-white group-hover:text-brand-400 transition">Etna Psicología</h3>
                                    <p class="text-gray-300 mt-1 text-sm">Web Corporativa + Blog</p>
                                </div>
                                <span class="text-brand-400 text-xs font-bold border border-brand-400 px-2 py-1 rounded hover:bg-brand-400 hover:text-white transition">Visitar ↗</span>
                            </div>
                            <div class="flex gap-2 mt-3">
                                <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded">WordPress</span>
                                <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded">Elementor</span>
                            </div>
                        </div>
                    </div>
                </a>

            </div>
        </div>
    </section>

    <section id="pricing" class="py-16 md:py-24 relative overflow-hidden px-4">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-white mb-4">Planes Transparentes</h2>
            <p class="text-center text-gray-400 mb-10">Invierte en tu negocio, no gastes en humo.</p>

            <div class="grid md:grid-cols-3 gap-6 md:gap-8">
                <div class="bg-gray-800 p-6 md:p-8 rounded-3xl border border-gray-700 flex flex-col" data-aos="fade-up">
                    <span class="bg-blue-900 text-blue-300 text-xs font-bold px-2 py-1 rounded w-fit mb-2">OFICIOS / RÁPIDO</span>
                    <h3 class="text-xl font-bold text-white">Web "Tarjeta"</h3>
                    <div class="my-3 text-4xl font-bold text-white flex items-baseline gap-1"><span class="text-lg font-normal text-gray-400">Desde</span> 180€</div>
                    <p class="text-xs text-gray-400 mb-4">Ideal Reformas, Fontaneros, Urgencias...</p>
                    <ul class="space-y-3 text-gray-300 text-sm mb-6">
                        <li class="flex items-center gap-2"><i class="fa-solid fa-bolt text-brand-400"></i> Carga Ultra Rápida</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-400"></i> Botón "Llamar Ahora"</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-400"></i> Ubicación Mapa</li>
                    </ul>
                    <p class="text-[10px] text-gray-500 mb-4 italic">* Hosting y Dominio no incluidos</p>
                    <a href="https://wa.me/34600000000?text=Hola, quiero la Web Rápida de 180" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp para empezar con la Web Rápida" class="mt-auto block text-center w-full py-3 border border-gray-600 rounded-xl text-white hover:bg-gray-700 transition text-sm font-bold">Solicitar presupuesto</a>
                </div>

                <div class="bg-gray-800 p-6 md:p-8 rounded-3xl border-2 border-brand-500 relative flex flex-col md:-translate-y-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="absolute top-0 right-0 bg-brand-500 text-white text-xs font-bold px-3 py-1 rounded-bl-xl rounded-tr-xl">POPULAR</div>
                    <span class="bg-pink-900 text-pink-300 text-xs font-bold px-2 py-1 rounded w-fit mb-2">PROFESIONAL + SEO</span>
                    <h3 class="text-xl font-bold text-white">Web Negocio</h3>
                    <div class="my-3 text-4xl font-bold text-white flex items-baseline gap-1"><span class="text-lg font-normal text-gray-400">Desde</span> 390€</div>
                    <p class="text-xs text-gray-400 mb-4">Ideal Psicólogos, Clínicas, Abogados...</p>
                    <ul class="space-y-3 text-gray-300 text-sm mb-6">
                        <li class="flex items-center gap-2"><i class="fa-solid fa-star text-brand-400"></i> <strong>SEO Básico Incluido</strong></li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-pen-nib text-brand-400"></i> Blog para Artículos</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-400"></i> Autogestionable (WordPress)</li>
                    </ul>
                    <p class="text-[10px] text-gray-500 mb-4 italic">* Hosting y Dominio no incluidos</p>
                    <a href="https://wa.me/34600000000?text=Hola, quiero la Web Profesional de 390" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp para la Web Profesional" class="mt-auto block text-center w-full py-3 bg-brand-500 rounded-xl text-white font-bold hover:bg-brand-400 transition shadow-lg shadow-brand-500/30 text-sm">Quiero Vender Más</a>
                </div>

                <div class="bg-gray-800 p-6 md:p-8 rounded-3xl border border-gray-700 flex flex-col" data-aos="fade-up" data-aos-delay="200">
                    <span class="bg-purple-900 text-purple-300 text-xs font-bold px-2 py-1 rounded w-fit mb-2">VENTA PRODUCTOS</span>
                    <h3 class="text-xl font-bold text-white">Tienda Online</h3>
                    <div class="my-3 text-4xl font-bold text-white flex items-baseline gap-1"><span class="text-lg font-normal text-gray-400">Desde</span> 550€</div>
                    <p class="text-xs text-gray-400 mb-4">Vende ropa, artesanía, cursos...</p>
                    <ul class="space-y-3 text-gray-300 text-sm mb-6">
                        <li class="flex items-center gap-2"><i class="fa-brands fa-wordpress text-brand-400"></i> WooCommerce</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-400"></i> Pasarela de Pagos</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-400"></i> Gestión de Pedidos</li>
                    </ul>
                    <p class="text-[10px] text-gray-500 mb-4 italic">* Hosting y Dominio no incluidos</p>
                    <a href="https://wa.me/34600000000?text=Hola, quiero montar una Tienda Online" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp para montar una Tienda Online" class="mt-auto block text-center w-full py-3 border border-gray-600 rounded-xl text-white hover:bg-gray-700 transition text-sm font-bold">Consultar</a>
                </div>
            </div>
        </div>
    </section>
    </main>

    <footer class="border-t border-gray-800 bg-dark-900 pt-16 pb-8 px-4 mb-16 md:mb-0">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12">
                <div class="text-center md:text-left">
                    <span class="text-2xl font-bold text-white block mb-4">WebDavid.es</span>
                    <p class="text-gray-400 text-sm leading-relaxed max-w-xs mx-auto md:mx-0">Diseño y desarrollo web a medida para negocios que buscan resultados reales.</p>
                </div>
                <div class="text-center">
                    <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Servicios</h4>
                    <ul class="space-y-3 text-sm text-gray-400">
                        <li><a href="#servicios" class="hover:text-brand-400 transition">Diseño Web</a></li>
                        <li><a href="#servicios" class="hover:text-brand-400 transition">WordPress</a></li>
                        <li><a href="#servicios" class="hover:text-brand-400 transition">Tiendas Online</a></li>
                    </ul>
                </div>
                <div class="text-center md:text-right">
                    <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Legal</h4>
                    <ul class="space-y-3 text-sm text-gray-400">
                        <li><a href="/aviso-legal" class="hover:text-brand-400 transition">Aviso Legal</a></li>
                        <li><a href="/politica-privacidad" class="hover:text-brand-400 transition">Política Privacidad</a></li>
                        <li><a href="/politica-cookies" class="hover:text-brand-400 transition">Política Cookies</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-gray-800 pt-8 text-center"><p class="text-gray-400 text-xs">© 2026 WebDavid - Todos los derechos reservados.</p></div>
        </div>
    </footer>

    <button onclick="toggleChat()" aria-label="Abrir calculadora de presupuesto" class="fixed bottom-6 right-6 bg-brand-500 hover:bg-brand-600 text-white p-4 rounded-full shadow-lg shadow-brand-500/40 z-50 transition-all hover:scale-110 group animate-bounce-short">
        <i class="fa-solid fa-comment-dots text-2xl group-hover:hidden"></i>
        <i class="fa-solid fa-xmark text-2xl hidden group-hover:block"></i>
    </button>

    <div id="chatWindow" class="fixed bottom-24 left-4 right-4 md:left-auto md:right-6 md:w-96 bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 z-50 hidden transform transition-all origin-bottom-right flex flex-col max-h-[60vh] md:max-h-[500px]">
        <div class="bg-brand-600 p-4 rounded-t-2xl flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <div class="relative"><div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-brand-600 font-bold">D</div><div class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-brand-600 rounded-full"></div></div>
                <div><h4 class="text-white font-bold text-sm">David - Web Designer</h4><p class="text-blue-100 text-xs">Calcula tu precio</p></div>
            </div>
            <button onclick="resetChat()" aria-label="Reiniciar conversación" class="text-white hover:text-blue-200 transition p-2"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i></button>
        </div>
        <div id="chatBody" class="p-4 overflow-y-auto bg-gray-900 space-y-4 flex-1">
            <div class="message-enter flex gap-2"><div class="bg-gray-700 p-3 rounded-2xl rounded-tl-none text-sm text-gray-200 border border-gray-600 max-w-[85%]">👋 ¡Hola! ¿Calculamos un precio para tu web?</div></div>
            <div id="options-start" class="flex flex-col gap-2 ml-8 message-enter" style="animation-delay: 0.1s;">
                <button onclick="userReply(180, 'Web Rápida (Desde 180€)', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🚀 Web Oficios/Rápida</button>
                <button onclick="userReply(350, 'Web Profesional + SEO', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🏢 Web Profesional</button>
                <button onclick="userReply(550, 'Tienda Online (Desde 550€)', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🛍️ Tienda Online</button>
            </div>
            <div id="typingIndicator" class="hidden flex gap-2"><div class="bg-gray-700 p-4 rounded-2xl rounded-tl-none border border-gray-600 flex gap-1"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>
        </div>
    </div>

    <div id="cookieBanner" class="fixed bottom-0 left-0 w-full z-[10000] bg-gray-900 border-t border-gray-700 p-6 shadow-2xl hidden flex-col md:flex-row items-center gap-4 justify-between pb-8 md:pb-6 md:rounded-t-2xl md:left-auto md:right-4 md:w-auto md:max-w-xl md:bottom-4 md:border">
        <div class="flex items-start gap-4 w-full">
            <span class="text-3xl animate-bounce">🍪</span>
            <p class="text-gray-300 text-sm leading-relaxed">Usamos cookies para mejorar tu experiencia. <a href="/politica-cookies" class="text-brand-400 font-bold hover:underline">Política</a>.</p>
        </div>
        <div class="flex gap-3 w-full md:w-auto shrink-0">
            <button onclick="acceptCookies()" class="flex-1 md:flex-none bg-blue-800 hover:bg-blue-700 text-white py-3 px-6 rounded-xl font-bold text-sm shadow-lg shadow-blue-900/30 active:scale-95">Aceptar</button>
            <button onclick="rejectCookies()" class="flex-1 md:flex-none bg-gray-800 border border-gray-600 hover:bg-gray-700 text-gray-300 hover:text-white py-3 px-4 rounded-xl text-sm font-medium active:scale-95">Rechazar</button>
        </div>
    </div>

  <Fragment slot="scripts">
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof AOS !== 'undefined') {
                AOS.init({ duration: 800, once: true });
            }
        });

        // MENÚ MÓVIL
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const icon = mobileBtn.querySelector('i');
        let isMenuOpen = false;

        mobileBtn.addEventListener('click', toggleMenu);

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;
            mobileBtn.setAttribute('aria-expanded', isMenuOpen);
            mobileBtn.setAttribute('aria-label', isMenuOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
            if (isMenuOpen) {
                mobileMenu.classList.remove('-translate-y-[150%]');
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-xmark');
                icon.classList.add('rotate-90');
            } else {
                mobileMenu.classList.add('-translate-y-[150%]');
                icon.classList.remove('fa-xmark');
                icon.classList.remove('rotate-90');
                icon.classList.add('fa-bars');
            }
        }
        window.addEventListener('scroll', () => { if (isMenuOpen) toggleMenu(); });

        // LÓGICA CHAT
        let presupuesto = 0;
        let resumen = "";
        const chatBody = document.getElementById('chatBody');
        let typingIndicator = document.getElementById('typingIndicator');

        function toggleChat() { document.getElementById('chatWindow').classList.toggle('hidden'); }

        function resetChat() {
            presupuesto = 0;
            resumen = "";
            chatBody.innerHTML = `
                <div class="message-enter flex gap-2"><div class="bg-gray-700 p-3 rounded-2xl rounded-tl-none text-sm text-gray-200 border border-gray-600 max-w-[85%]">🔄 ¡Empezamos de nuevo! ¿Qué tipo de web tienes en mente?</div></div>
                <div id="options-start" class="flex flex-col gap-2 ml-8 message-enter" style="animation-delay: 0.1s;">
                    <button onclick="userReply(180, 'Web Rápida (Desde 180€)', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🚀 Web Oficios/Rápida</button>
                    <button onclick="userReply(350, 'Web Profesional + SEO', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🏢 Web Profesional</button>
                    <button onclick="userReply(550, 'Tienda Online (Desde 550€)', 1)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🛍️ Tienda Online</button>
                </div>
                <div id="typingIndicator" class="hidden flex gap-2"><div class="bg-gray-700 p-4 rounded-2xl rounded-tl-none border border-gray-600 flex gap-1"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>
            `;
            typingIndicator = document.getElementById('typingIndicator');
        }

        function botType(htmlContent, delay = 600) {
            chatBody.appendChild(typingIndicator);
            typingIndicator.classList.remove('hidden');
            chatBody.scrollTop = chatBody.scrollHeight;
            setTimeout(() => {
                typingIndicator.classList.add('hidden');
                const div = document.createElement('div');
                div.className = `message-enter flex gap-2`;
                div.innerHTML = `<div class="bg-gray-700 p-3 rounded-2xl rounded-tl-none text-sm text-gray-200 border border-gray-600 max-w-[85%]">${htmlContent}</div>`;
                chatBody.insertBefore(div, typingIndicator);
                chatBody.scrollTop = chatBody.scrollHeight;
            }, delay);
        }

        function userReply(price, text, step) {
            const lastOptions = chatBody.querySelector('.flex-col:not(.hidden)');
            if(lastOptions) lastOptions.remove();

            const userDiv = document.createElement('div');
            userDiv.className = `message-enter flex gap-2 justify-end`;
            userDiv.innerHTML = `<div class="bg-brand-600 text-white p-3 rounded-2xl rounded-tr-none text-sm max-w-[85%]">${text}</div>`;
            chatBody.insertBefore(userDiv, typingIndicator);
            
            presupuesto += price;
            resumen += `- ${text}\n`;

            if (step === 1) {
                botType("Genial. <strong>¿Tienes ya el Logotipo y los Textos?</strong>");
                setTimeout(() => {
                    const options = `
                        <div class="flex flex-col gap-2 ml-8 message-enter">
                            <button onclick="userReply(0, 'Sí, tengo todo listo', 2)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">✅ Sí, lo tengo todo</button>
                            <button onclick="userReply(0, 'Necesito ayuda diseño', 2)" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">🎨 No, necesito ayuda</button>
                        </div>`;
                    const div = document.createElement('div');
                    div.innerHTML = options;
                    chatBody.insertBefore(div.firstElementChild, typingIndicator);
                    chatBody.scrollTop = chatBody.scrollHeight;
                }, 700);
            } 
            else if (step === 2) {
                botType("Entendido. <strong>¿Quieres salir en Google (SEO)?</strong>");
                setTimeout(() => {
                    const options = `
                        <div class="flex flex-col gap-2 ml-8 message-enter">
                            <button onclick="finishChat(40, 'Sí, quiero SEO')" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">📈 Sí, posicionarme (+40€)</button>
                            <button onclick="finishChat(0, 'No por ahora')" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 text-brand-400 text-sm py-3 px-4 rounded-lg text-left transition active:bg-gray-700">💨 No, solo la web</button>
                        </div>`;
                    const div = document.createElement('div');
                    div.innerHTML = options;
                    chatBody.insertBefore(div.firstElementChild, typingIndicator);
                    chatBody.scrollTop = chatBody.scrollHeight;
                }, 700);
            }
        }

        function finishChat(price, text) {
            const lastOptions = chatBody.querySelector('.flex-col:not(.hidden)');
            if(lastOptions) lastOptions.remove();

            const userDiv = document.createElement('div');
            userDiv.className = `message-enter flex gap-2 justify-end`;
            userDiv.innerHTML = `<div class="bg-brand-600 text-white p-3 rounded-2xl rounded-tr-none text-sm max-w-[85%]">${text}</div>`;
            chatBody.insertBefore(userDiv, typingIndicator);

            presupuesto += price;
            resumen += `- ${text}`;

            botType(`Calculando presupuesto...`, 600);
            
            setTimeout(() => {
                let msgPrecio = presupuesto > 0 ? `Desde ${presupuesto}€` : "A consultar";
                const finalMsg = `Hola David, quiero empezar mi proyecto:%0A${encodeURIComponent(resumen)}%0A----------------%0APrecio estimado: ${msgPrecio}%0A(Hosting y dominio aparte)`;
                
                const cta = `
                    <div class="mt-4 text-center message-enter">
                        <div class="text-3xl font-bold text-white mb-2 animate-bounce-short">${msgPrecio}</div>
                        <p class="text-[10px] text-gray-400 mb-2">Al contactar, aceptas la <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.</p>
                        <a href="https://wa.me/34600000000?text=${finalMsg}" target="_blank" title="Contactar por WhatsApp" aria-label="Contactar por WhatsApp con el presupuesto calculado" class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-full shadow-lg shadow-green-500/30 transition transform hover:scale-105"><i class="fa-brands fa-whatsapp" aria-hidden="true"></i> Hablar por WhatsApp</a>
                    </div>`;
                const div = document.createElement('div');
                div.innerHTML = cta;
                chatBody.appendChild(div);
                chatBody.scrollTop = chatBody.scrollHeight;
            }, 1400);
        }

        // COOKIES
        document.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('cookiesConsent')) {
                const banner = document.getElementById('cookieBanner');
                banner.classList.remove('hidden');
                banner.style.display = 'flex';
            }
        });

        function acceptCookies() { localStorage.setItem('cookiesConsent', 'accepted'); document.getElementById('cookieBanner').style.display = 'none'; }
        function rejectCookies() { localStorage.setItem('cookiesConsent', 'rejected'); document.getElementById('cookieBanner').style.display = 'none'; }
    </script>
  </Fragment>
</BaseLayout>