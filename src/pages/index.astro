---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import electricistaImg from '../assets/images/electricista.png';
import etnaImg from '../assets/images/etnapsicologia.png';
---

<BaseLayout
  title="WebDavid | Desarrollo Web de Alto Rendimiento para Negocios Locales"
  description="Webs ultrarrápidas que convierten visitas en llamadas. Comprueba gratis si Google está penalizando tu negocio local."
  canonical="https://webdavid.es/"
>
  <Fragment slot="head">
    <meta property="og:title" content="WebDavid | Alto Rendimiento Web para Negocios Locales" />
    <meta property="og:description" content="El 80% de tus clientes buscan en móvil. Si tu web es lenta, pierdes dinero. Audita tu web gratis en 15 segundos." />
    <meta property="og:url" content="https://webdavid.es/" />
    <meta property="og:type" content="website" />
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "WebDavid",
        "url": "https://webdavid.es",
        "description": "Desarrollo web de alto rendimiento y auditorías Core Web Vitals para negocios locales."
      }
    </script>
  </Fragment>

  <nav class="fixed w-full z-50 glass-card border-b border-gray-800/80">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <a href="/" class="font-display font-bold text-xl tracking-tight text-white flex items-center gap-2 z-50">
          <span class="text-brand-400">&lt;/&gt;</span> WebDavid
        </a>
        <div class="hidden md:flex items-center gap-10">
          <a href="#servicios" class="text-gray-400 hover:text-white transition text-sm font-medium">Servicios</a>
          <a href="#portfolio" class="text-gray-400 hover:text-white transition text-sm font-medium">Resultados</a>
          <a href="/auditoria" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-lg font-semibold text-sm transition shadow-lg shadow-blue-900/30">
            Auditar mi web
          </a>
        </div>
        <button id="mobile-menu-btn" aria-label="Abrir menú de navegación" aria-expanded="false" class="md:hidden text-white p-2 focus:outline-none z-50">
          <span id="icon-bars" class="block"><Icon name="bars" class="w-7 h-7" /></span>
          <span id="icon-close" class="hidden"><Icon name="xmark" class="w-7 h-7" /></span>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="absolute top-20 left-0 w-full bg-dark-900 border-b border-gray-800 shadow-2xl md:hidden transform -translate-y-[150%] transition-transform duration-300 ease-in-out -z-10">
      <div class="flex flex-col items-center py-8 gap-6">
        <a href="#servicios" onclick="toggleMenu()" class="text-lg text-white font-semibold hover:text-brand-400">Servicios</a>
        <a href="#portfolio" onclick="toggleMenu()" class="text-lg text-white font-semibold hover:text-brand-400">Resultados</a>
        <a href="/auditoria" onclick="toggleMenu()" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-bold">Auditar mi web</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- HERO -->
    <section class="relative pt-32 pb-20 lg:pt-44 lg:pb-28 overflow-hidden px-4">
      <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/20 rounded-full blur-[128px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-500/10 rounded-full blur-[128px] pointer-events-none"></div>

      <div class="max-w-4xl mx-auto text-center relative z-10" data-reveal>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-800/80 border border-gray-700 text-xs sm:text-sm text-gray-300 mb-8 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Especialista en Core Web Vitals · Negocios locales
        </div>

        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-[1.08]">
          El 80% de tus clientes buscan en móvil.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-brand-400">
            Si tu web es lenta, se van a tu competencia.
          </span>
        </h1>

        <p class="max-w-2xl mx-auto text-lg sm:text-xl text-gray-400 mb-12 leading-relaxed">
          Desarrollo web de alto rendimiento para negocios locales. Comprueba en 15 segundos si Google te está escondiendo.
        </p>

        <!-- Mini-formulario embudo -->
        <form
          action="/auditoria"
          method="get"
          class="max-w-xl mx-auto text-left p-6 sm:p-8 rounded-2xl border border-gray-700/80 bg-gray-900/60 backdrop-blur-xl shadow-2xl shadow-blue-900/20"
        >
          <div class="space-y-4">
            <div>
              <label for="hero-url" class="block text-sm font-medium text-gray-300 mb-2">URL de tu página web</label>
              <input
                type="url"
                id="hero-url"
                name="url"
                required
                placeholder="https://tuempresa.es"
                autocomplete="url"
                class="w-full px-4 py-3.5 rounded-xl bg-gray-800/80 border border-gray-600 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/25 transition"
              />
            </div>
            <div>
              <label for="hero-email" class="block text-sm font-medium text-gray-300 mb-2">Tu email</label>
              <input
                type="email"
                id="hero-email"
                name="email"
                required
                placeholder="tucorreo@empresa.es"
                autocomplete="email"
                class="w-full px-4 py-3.5 rounded-xl bg-gray-800/80 border border-gray-600 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/25 transition"
              />
            </div>
            <button
              type="submit"
              class="w-full py-4 px-6 bg-blue-600 hover:bg-blue-500 text-white font-display font-bold text-lg rounded-xl transition shadow-lg shadow-blue-900/40 active:scale-[0.98]"
            >
              Auditar mi web GRATIS
            </button>
            <p class="text-center text-xs text-gray-500">Sin spam. Informe técnico en tu correo en minutos.</p>
          </div>
        </form>
      </div>
    </section>

    <!-- PRUEBA DE AUTORIDAD -->
    <section class="border-y border-gray-800 bg-dark-800/50 py-12 px-4" data-reveal>
      <div class="max-w-5xl mx-auto">
        <p class="text-center text-sm uppercase tracking-widest text-gray-500 mb-10 font-medium">
          No te fíes de mí, fíjate en los datos de Google
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {[
            { score: '100', label: 'Rendimiento', color: 'text-green-400', ring: 'border-green-500/30' },
            { score: '100', label: 'Accesibilidad', color: 'text-green-400', ring: 'border-green-500/30' },
            { score: '100', label: 'Prácticas', color: 'text-green-400', ring: 'border-green-500/30' },
            { score: '100', label: 'SEO', color: 'text-green-400', ring: 'border-green-500/30' },
          ].map((m) => (
            <div class={`flex flex-col items-center p-6 rounded-2xl bg-gray-900/80 border ${m.ring} shadow-xl`}>
              <div class={`font-display text-4xl md:text-5xl font-bold ${m.color} mb-2`}>{m.score}</div>
              <div class="text-sm text-gray-400 font-medium text-center">{m.label}</div>
              <div class="mt-3 w-full h-1.5 bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full w-full bg-green-500 rounded-full"></div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center text-xs text-gray-600 mt-8">Métricas PageSpeed Insights · webdavid.es</p>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="py-24 lg:py-32 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 max-w-2xl mx-auto" data-reveal>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
            Tu web no es un folleto. Es tu mejor vendedor.
          </h2>
          <p class="text-gray-400 text-lg">Cada segundo de carga que pierdes es una llamada que no entra.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
          <article
            class="group p-8 lg:p-10 rounded-2xl bg-gray-900/50 border border-gray-800 hover:border-blue-500/40 transition duration-500 shadow-2xl shadow-blue-900/10"
            data-reveal
          >
            <div class="w-14 h-14 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center mb-6">
              <Icon name="bolt" class="w-7 h-7 text-blue-400" />
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-4">Rendimiento Extremo</h3>
            <p class="text-gray-400 leading-relaxed text-base">
              Código puro para webs de servicios que necesitan que el teléfono suene ya. Sin plantillas pesadas, sin plugins que te frenan en Google.
            </p>
            <ul class="mt-6 space-y-2 text-sm text-gray-500">
              <li class="flex items-center gap-2"><Icon name="check" class="w-4 h-4 text-green-400 shrink-0" /> Core Web Vitals optimizados</li>
              <li class="flex items-center gap-2"><Icon name="check" class="w-4 h-4 text-green-400 shrink-0" /> Carga en menos de 1 segundo</li>
            </ul>
          </article>

          <article
            class="group p-8 lg:p-10 rounded-2xl bg-gray-900/50 border border-gray-800 hover:border-brand-500/40 transition duration-500 shadow-2xl shadow-blue-900/10"
            data-reveal
            data-reveal-delay="100"
          >
            <div class="w-14 h-14 rounded-xl bg-brand-500/20 border border-brand-500/30 flex items-center justify-center mb-6">
              <Icon name="pen" class="w-7 h-7 text-brand-400" />
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-4">Autogestión Total</h3>
            <p class="text-gray-400 leading-relaxed text-base">
              Plataformas sólidas si necesitas publicar artículos o gestionar reservas. Rápidas, seguras y pensadas para que tú mandes sin depender de nadie.
            </p>
            <ul class="mt-6 space-y-2 text-sm text-gray-500">
              <li class="flex items-center gap-2"><Icon name="check" class="w-4 h-4 text-green-400 shrink-0" /> Blog y contenidos SEO</li>
              <li class="flex items-center gap-2"><Icon name="check" class="w-4 h-4 text-green-400 shrink-0" /> Reservas y formularios integrados</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- PORTFOLIO -->
    <section id="portfolio" class="py-24 lg:py-32 bg-dark-800/80 border-y border-gray-800 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16" data-reveal>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Resultados en negocios reales</h2>
          <p class="text-gray-400 max-w-xl mx-auto">Webs construidas para convertir búsquedas locales en clientes, no para ganar concursos de diseño.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
          <a href="https://www.averiascadiz.es" target="_blank" rel="noopener noreferrer" class="group block" data-reveal>
            <div class="overflow-hidden rounded-2xl border border-gray-800 bg-gray-900 shadow-2xl shadow-blue-900/20 transition-all duration-300 group-hover:-translate-y-1 group-hover:border-gray-700">
              <Image
                src={electricistaImg}
                alt="Web de Averías Cádiz, electricista de urgencias con alto rendimiento móvil"
                width={800}
                height={450}
                format="avif"
                loading="lazy"
                decoding="async"
                class="w-full h-56 md:h-72 object-cover opacity-90 group-hover:opacity-100 transition duration-500"
              />
              <div class="p-6">
                <h3 class="text-xl font-bold text-white group-hover:text-brand-400 transition">Averías Cádiz</h3>
                <p class="text-gray-400 text-sm mt-1">Urgencias eléctricas · SEO local</p>
                <div class="flex gap-2 mt-4">
                  <span class="text-xs font-mono text-green-400/90 bg-green-500/10 border border-green-500/20 px-2 py-1 rounded">100 PageSpeed móvil</span>
                  <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded border border-gray-700">HTML nativo</span>
                </div>
              </div>
            </div>
          </a>

          <a href="https://www.etnapsicologia.com" target="_blank" rel="noopener noreferrer" class="group block" data-reveal data-reveal-delay="100">
            <div class="overflow-hidden rounded-2xl border border-gray-800 bg-gray-900 shadow-2xl shadow-blue-900/20 transition-all duration-300 group-hover:-translate-y-1 group-hover:border-gray-700">
              <Image
                src={etnaImg}
                alt="Web de Etna Psicología, clínica con blog y optimización de rendimiento"
                width={800}
                height={450}
                format="avif"
                loading="lazy"
                decoding="async"
                class="w-full h-56 md:h-72 object-cover opacity-90 group-hover:opacity-100 transition duration-500"
              />
              <div class="p-6">
                <h3 class="text-xl font-bold text-white group-hover:text-brand-400 transition">Etna Psicología</h3>
                <p class="text-gray-400 text-sm mt-1">Clínica + blog · Captación de pacientes</p>
                <div class="flex gap-2 mt-4">
                  <span class="text-xs font-mono text-green-400/90 bg-green-500/10 border border-green-500/20 px-2 py-1 rounded">SEO + Blog</span>
                  <span class="text-xs font-mono text-gray-400 bg-gray-800 px-2 py-1 rounded border border-gray-700">Autogestionable</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="py-24 lg:py-32 px-4">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
          ¿Cuántos clientes perdiste esta semana por una web lenta?
        </h2>
        <p class="text-gray-400 text-lg mb-10 leading-relaxed">
          La auditoría es gratuita. En minutos sabrás exactamente qué está frenando tu negocio en Google.
        </p>
        <a
          href="/auditoria"
          class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-display font-bold text-lg px-10 py-4 rounded-xl transition shadow-2xl shadow-blue-900/30"
        >
          Auditar mi web GRATIS
        </a>
      </div>
    </section>
  </main>

  <footer class="border-t border-gray-800 bg-dark-900 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
        <div>
          <span class="font-display text-xl font-bold text-white block mb-4">WebDavid.es</span>
          <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
            Desarrollo web de alto rendimiento para negocios locales que no pueden permitirse perder clientes en Google.
          </p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Enlaces</h4>
          <ul class="space-y-3 text-sm text-gray-400">
            <li><a href="/auditoria" class="hover:text-brand-400 transition">Auditoría gratuita</a></li>
            <li><a href="#servicios" class="hover:text-brand-400 transition">Servicios</a></li>
            <li><a href="#portfolio" class="hover:text-brand-400 transition">Resultados</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Legal</h4>
          <ul class="space-y-3 text-sm text-gray-400">
            <li><a href="/aviso-legal" class="hover:text-brand-400 transition">Aviso Legal</a></li>
            <li><a href="/politica-privacidad" class="hover:text-brand-400 transition">Política Privacidad</a></li>
            <li><a href="/politica-cookies" class="hover:text-brand-400 transition">Política Cookies</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 pt-8 text-center">
        <p class="text-gray-400 text-xs">© 2026 WebDavid — Alto rendimiento web para negocios locales</p>
      </div>
    </div>
  </footer>

  <div id="cookieBanner" class="fixed bottom-0 left-0 w-full z-[10000] bg-gray-900/95 backdrop-blur border-t border-gray-800 p-6 shadow-2xl hidden flex-col md:flex-row items-center gap-4 justify-between md:left-auto md:right-4 md:bottom-4 md:max-w-xl md:rounded-xl md:border">
    <p class="text-gray-300 text-sm leading-relaxed">
      Usamos cookies para mejorar tu experiencia. <a href="/politica-cookies" class="text-brand-400 font-semibold hover:underline">Política</a>.
    </p>
    <div class="flex gap-3 shrink-0">
      <button onclick="acceptCookies()" class="bg-blue-800 hover:bg-blue-700 text-white py-2.5 px-5 rounded-lg font-semibold text-sm transition">Aceptar</button>
      <button onclick="rejectCookies()" class="bg-gray-800 border border-gray-600 text-gray-300 py-2.5 px-4 rounded-lg text-sm hover:bg-gray-700 transition">Rechazar</button>
    </div>
  </div>

  <Fragment slot="scripts">
    <script is:inline>
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconBars = document.getElementById('icon-bars');
      const iconClose = document.getElementById('icon-close');
      let isMenuOpen = false;

      function toggleMenu() {
        isMenuOpen = !isMenuOpen;
        mobileBtn.setAttribute('aria-expanded', isMenuOpen);
        mobileBtn.setAttribute('aria-label', isMenuOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
        if (isMenuOpen) {
          mobileMenu.classList.remove('-translate-y-[150%]');
          iconBars.classList.add('hidden');
          iconClose.classList.remove('hidden');
        } else {
          mobileMenu.classList.add('-translate-y-[150%]');
          iconClose.classList.add('hidden');
          iconBars.classList.remove('hidden');
        }
      }

      mobileBtn.addEventListener('click', toggleMenu);
      window.addEventListener('scroll', () => { if (isMenuOpen) toggleMenu(); });

      document.addEventListener('DOMContentLoaded', () => {
        if (!localStorage.getItem('cookiesConsent')) {
          const banner = document.getElementById('cookieBanner');
          banner.classList.remove('hidden');
          banner.style.display = 'flex';
        }
      });

      function acceptCookies() {
        localStorage.setItem('cookiesConsent', 'accepted');
        document.getElementById('cookieBanner').style.display = 'none';
      }
      function rejectCookies() {
        localStorage.setItem('cookiesConsent', 'rejected');
        document.getElementById('cookieBanner').style.display = 'none';
      }
    </script>
  </Fragment>
</BaseLayout>
